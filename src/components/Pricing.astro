---
const plans = [
  {
    name: "Student",
    price: "$0",
    description: "Perfect for getting started with digital note-taking on iPad.",
    features: [
      "Unlimited infinite canvas",
      "Basic pen & drawing tools",
      "1 AI model included",
      "3 Notebooks",
      "Local storage only",
      "Export to PDF/Image"
    ],
    cta: "Join Waitlist",
    highlight: false
  },
  {
    name: "Pro",
    price: "$7.99",
    period: "/month",
    description: "For power users who need advanced organization and full AI access.",
    features: [
      "Everything in Student",
      "Unlimited Notebooks",
      "All AI models (full roadmap access)",
      "Unlimited Cloud Sync",
      "Advanced Search (OCR)",
      "Early Access to new features"
    ],
    cta: "Join Waitlist",
    highlight: true
  }
];
---

<section id="pricing" class="py-24 bg-[#0a0a0a]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-bold mb-6">Simple, transparent pricing</h2>
      <p class="text-xl text-gray-400">Start for free, upgrade to unlock cloud sync and advanced AI.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      {plans.map(plan => (
        <div class={`relative p-8 rounded-3xl border flex flex-col ${plan.highlight ? 'bg-white/5 border-brand-gold/50 shadow-2xl shadow-brand-gold/10' : 'bg-transparent border-white/10'}`}>
          {plan.highlight && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-gradient-to-r from-brand-gold-light to-brand-gold-dark text-black px-4 py-1 rounded-full text-sm font-medium shadow-lg">
              Save with $79.99/yr
            </div>
          )}
          
          <div class="mb-8">
            <h3 class="text-xl font-semibold text-white mb-2">{plan.name}</h3>
            <div class="flex items-baseline gap-1">
              <span class="text-4xl font-bold text-white">{plan.price}</span>
              {plan.period && <span class="text-gray-500">{plan.period}</span>}
            </div>
            <p class="text-gray-400 mt-4 text-sm">{plan.description}</p>
          </div>

          <ul class="space-y-4 mb-8 flex-1">
            {plan.features.map(feature => (
              <li class="flex items-start gap-3 text-gray-300 text-sm">
                <svg class={`w-5 h-5 flex-shrink-0 ${plan.highlight ? 'text-brand-gold' : 'text-gray-500'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                {feature}
              </li>
            ))}
          </ul>

          <a href="#waitlist" class={`w-full py-3 px-6 rounded-xl font-medium text-center transition-colors ${plan.highlight ? 'bg-brand-gold text-black hover:bg-brand-gold-light' : 'bg-white/10 text-white hover:bg-white/20'}`}>
            {plan.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
