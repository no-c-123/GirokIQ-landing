---
---

<section class="py-24 bg-dark-bg overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="relative rounded-3xl bg-linear-to-b from-[#111] to-[#0a0a0a] border border-white/10 p-12 md:p-24 overflow-hidden">
      
      <!-- Background Grid Animation -->
      <div class="absolute inset-0 opacity-20 pointer-events-none">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px]"></div>
      </div>

      <div class="relative z-10 max-w-3xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-gold/10 text-brand-gold text-sm font-medium mb-6 border border-brand-gold/20">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          Native iPadOS Performance
        </div>
        
        <h2 class="text-4xl md:text-6xl font-bold mb-6 text-white tracking-tight">
          Performance at the <br/> speed of thought
        </h2>
        
        <p class="text-xl text-gray-400 mb-12 leading-relaxed">
          Powered by SwiftUI and PencilKit, GirokIQ delivers a buttery-smooth 120fps experience on ProMotion displays.
        </p>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 border-t border-white/10 pt-12">
          <div>
            <div class="text-3xl font-bold text-white mb-1">120<span class="text-sm text-gray-500 ml-1">fps</span></div>
            <div class="text-sm text-gray-500">ProMotion Ready</div>
          </div>
          <div>
            <div class="text-3xl font-bold text-white mb-1">&lt;9<span class="text-sm text-gray-500 ml-1">ms</span></div>
            <div class="text-sm text-gray-500">Pencil Latency</div>
          </div>
          <div>
            <div class="text-3xl font-bold text-white mb-1">∞</div>
            <div class="text-sm text-gray-500">Canvas Size</div>
          </div>
          <div>
            <div class="text-3xl font-bold text-white mb-1">100%</div>
            <div class="text-sm text-gray-500">Native Code</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
