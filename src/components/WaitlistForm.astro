---
// WaitlistForm.astro
---

<div class="w-full max-w-md mx-auto waitlist-container">
  <form class="waitlist-form flex flex-col sm:flex-row gap-3 w-full">
    <input 
      type="email" 
      name="email" 
      placeholder="Enter your email address" 
      required 
      class="email-input flex-1 px-4 py-3.5 rounded-lg bg-white/5 border border-white/10 text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-gold transition-all shadow-inner"
    />
    <button 
      type="submit" 
      class="submit-btn btn-primary px-6 py-3.5 whitespace-nowrap flex items-center justify-center gap-2 shadow-lg shadow-brand-gold/25 disabled:opacity-70 disabled:cursor-not-allowed"
    >
      <span class="btn-text">Join Waitlist</span>
      <svg class="spinner w-5 h-5 animate-spin hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
    </button>
  </form>
  <div class="form-message mt-3 text-sm text-center hidden"></div>
</div>

<script>
  import { supabase } from '../lib/supabase';

  const forms = document.querySelectorAll('.waitlist-form');

  forms.forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formEl = e.target as HTMLFormElement;
      const container = formEl.closest('.waitlist-container');
      if (!container) return;

      const emailInput = formEl.querySelector('.email-input') as HTMLInputElement;
      const submitBtn = formEl.querySelector('.submit-btn') as HTMLButtonElement;
      const btnText = formEl.querySelector('.btn-text');
      const spinner = formEl.querySelector('.spinner');
      const messageEl = container.querySelector('.form-message');
      
      const email = emailInput.value.trim();
      
      if (!email) return;

      // Ensure Supabase is configured
      if (!import.meta.env.PUBLIC_SUPABASE_URL || !import.meta.env.PUBLIC_SUPABASE_ANON_KEY) {
        if (messageEl) {
          messageEl.textContent = 'Waitlist is currently unavailable. Please try again later.';
          messageEl.className = 'form-message mt-3 text-sm text-center text-yellow-400 block';
        }
        return;
      }

      // Loading state
      submitBtn.disabled = true;
      if (btnText) btnText.textContent = 'Joining...';
      spinner?.classList.remove('hidden');
      if (messageEl) messageEl.classList.add('hidden');

      try {
        const { error } = await supabase
          .from('waitlist')
          .insert([{ email }]);

        if (error) {
          if (error.code === '23505') {
            throw new Error('You are already on the waitlist!');
          }
          throw error;
        }

        // Success
        formEl.reset();
        if (messageEl) {
          messageEl.textContent = 'Thanks for joining! We\'ll be in touch soon.';
          messageEl.className = 'form-message mt-3 text-sm text-center text-green-400 block';
        }
      } catch (err: any) {
        // Error
        if (messageEl) {
          messageEl.textContent = err.message || 'Something went wrong. Please try again.';
          messageEl.className = 'form-message mt-3 text-sm text-center text-red-400 block';
        }
      } finally {
        // Reset loading state
        submitBtn.disabled = false;
        if (btnText) btnText.textContent = 'Join Waitlist';
        spinner?.classList.add('hidden');
      }
    });
  });
</script>
