---
---

<section id="showcase" class="py-24 bg-[#0a0a0a] relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-bold mb-6">See the big picture</h2>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto">
        Zoom out to see your entire project at a glance. Zoom in to focus on the smallest detail.
      </p>
    </div>

    <div class="relative rounded-2xl border border-white/10 bg-[#121212] shadow-2xl overflow-hidden aspect-[16/9] group">
      <!-- UI Controls Overlay -->
      <div class="absolute bottom-6 right-6 flex gap-2 z-20">
        <button class="w-10 h-10 rounded-full bg-[#1a1a1a] border border-white/10 text-white flex items-center justify-center hover:bg-white/10 transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        </button>
        <button class="w-10 h-10 rounded-full bg-[#1a1a1a] border border-white/10 text-white flex items-center justify-center hover:bg-white/10 transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"></path></svg>
        </button>
      </div>

      <!-- Canvas Content -->
      <div class="absolute inset-0 bg-[#0a0a0a] overflow-hidden cursor-grab active:cursor-grabbing">
         <!-- Dot Grid -->
        <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(#4b5563 1px, transparent 1px); background-size: 20px 20px;"></div>
        
        <!-- Mock Content Group 1 -->
        <div class="absolute top-1/4 left-1/4 transform -translate-x-1/2 -translate-y-1/2">
            <div class="bg-[#1a1a1a] p-6 rounded-xl border border-white/10 w-80 shadow-lg">
                <div class="h-4 w-1/3 bg-blue-500/20 rounded mb-4"></div>
                <div class="space-y-3">
                    <div class="h-2 w-full bg-white/10 rounded"></div>
                    <div class="h-2 w-5/6 bg-white/10 rounded"></div>
                    <div class="h-2 w-4/6 bg-white/10 rounded"></div>
                </div>
                <div class="mt-6 flex gap-2">
                    <div class="w-8 h-8 rounded-full bg-purple-500/20"></div>
                    <div class="w-8 h-8 rounded-full bg-green-500/20"></div>
                </div>
            </div>
            <!-- Connection Line -->
             <svg class="absolute top-full left-1/2 w-40 h-40 -ml-0.5 pointer-events-none overflow-visible">
                <path d="M0,0 C0,50 100,50 100,100" fill="none" stroke="#374151" stroke-width="2" stroke-dasharray="4 4" />
             </svg>
        </div>

        <!-- Mock Content Group 2 -->
        <div class="absolute top-1/2 left-1/2 transform translate-x-10 translate-y-20">
             <div class="bg-[#1a1a1a] p-4 rounded-xl border border-white/10 w-64 shadow-lg rotate-2">
                <div class="h-32 bg-white/5 rounded-lg mb-4 flex items-center justify-center">
                    <svg class="w-12 h-12 text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                </div>
                <div class="h-3 w-1/2 bg-white/10 rounded"></div>
            </div>
        </div>
        
         <!-- Handwriting -->
         <svg class="absolute inset-0 pointer-events-none">
            <path d="M 600 200 Q 700 100 800 250 T 1000 300" fill="none" stroke="#8b5cf6" stroke-width="3" stroke-linecap="round" opacity="0.6" />
            <text x="820" y="240" fill="#8b5cf6" font-family="cursive" font-size="24" transform="rotate(-10 820 240)">Great Idea!</text>
         </svg>

      </div>
    </div>
  </div>
</section>
