---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Terms of Service - GirokIQ">
  <Navbar />
  
  <main class="pt-32 pb-24 relative overflow-hidden">
    <!-- Background Elements -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-[#C9A84C]/10 blur-[120px] rounded-full pointer-events-none"></div>
    
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="mb-12 text-center">
        <h1 class="text-4xl md:text-5xl font-serif text-white mb-4">Terms of Service</h1>
        <p class="text-gray-400">Last Updated: May 12, 2026</p>
      </div>

      <div class="space-y-12">
        <section>
          <p class="text-gray-300 leading-relaxed text-lg">
            Welcome to GirokIQ ("the App"). By creating an account or using the App, you agree to be bound by these Terms of Service ("Terms"). As GirokIQ is developed and operated by a solo developer, these terms constitute a legal agreement between you and the developer.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-semibold text-white mb-4 flex items-center gap-3">
            <span class="w-8 h-8 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-sm text-[#C9A84C]">1</span>
            Acceptance of Terms
          </h2>
          <p class="text-gray-300 leading-relaxed">
            By accessing or using GirokIQ, you confirm your capacity to enter into a binding agreement and your acceptance of these Terms. If you do not agree, you may not use the App.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-semibold text-white mb-4 flex items-center gap-3">
            <span class="w-8 h-8 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-sm text-[#C9A84C]">2</span>
            Account Responsibility
          </h2>
          <p class="text-gray-300 leading-relaxed">
            You are responsible for maintaining the confidentiality of your account credentials (Email, Apple ID) and for all activities that occur under your account. You agree to notify the developer immediately of any unauthorized use of your account.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-semibold text-white mb-6 flex items-center gap-3">
            <span class="w-8 h-8 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-sm text-[#C9A84C]">3</span>
            Content Ownership & License
          </h2>
          <div class="space-y-6">
            <div class="bg-white/5 border border-white/10 rounded-2xl p-6">
              <h3 class="text-xl font-medium text-white mb-3">Your Content</h3>
              <p class="text-gray-300 leading-relaxed">
                You retain full ownership of all notes, drawings, images, and text you create or upload to GirokIQ ("User Content"). We claim no ownership over your intellectual property.
              </p>
            </div>
            <div class="bg-white/5 border border-white/10 rounded-2xl p-6">
              <h3 class="text-xl font-medium text-white mb-3">License to Us</h3>
              <p class="text-gray-300 leading-relaxed">
                To provide the service (specifically cloud syncing via Supabase and AI processing via Anthropic), you grant the developer a worldwide, non-exclusive, royalty-free license to host, store, and process your content solely for the purpose of operating the App's features for you.
              </p>
            </div>
          </div>
        </section>

        <section>
          <h2 class="text-2xl font-semibold text-white mb-6 flex items-center gap-3">
            <span class="w-8 h-8 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-sm text-[#C9A84C]">4</span>
            AI Features & Disclaimers
          </h2>
          <p class="text-gray-300 leading-relaxed mb-6">
            GirokIQ utilizes third-party artificial intelligence (Anthropic's Claude API). By using AI features, you acknowledge that:
          </p>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <div class="w-1.5 h-1.5 rounded-full bg-[#C9A84C] mt-2.5 shrink-0"></div>
              <p class="text-gray-300">AI-generated responses may be inaccurate, incomplete, or biased.</p>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-1.5 h-1.5 rounded-full bg-[#C9A84C] mt-2.5 shrink-0"></div>
              <p class="text-gray-300">Content sent to the AI (including canvas screenshots for vision features) is processed by third-party servers.</p>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-1.5 h-1.5 rounded-full bg-[#C9A84C] mt-2.5 shrink-0"></div>
              <p class="text-gray-300">The developer is not responsible for any decisions made or actions taken based on AI-generated output.</p>
            </li>
          </ul>
        </section>

        <section>
          <h2 class="text-2xl font-semibold text-white mb-4 flex items-center gap-3">
            <span class="w-8 h-8 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-sm text-[#C9A84C]">5</span>
            Acceptable Use
          </h2>
          <p class="text-gray-300 leading-relaxed">
            You agree not to use the App for any illegal purposes or to upload content that is defamatory, infringing on intellectual property, or harmful. Abuse of the AI features (e.g., attempting to bypass safety filters or reverse-engineering the API) is strictly prohibited and may result in account termination.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-semibold text-white mb-4 flex items-center gap-3">
            <span class="w-8 h-8 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-sm text-[#C9A84C]">6</span>
            Limitation of Liability
          </h2>
          <div class="p-6 rounded-2xl bg-white/5 border border-white/10">
            <p class="text-gray-300 leading-relaxed uppercase text-sm tracking-wide">
              TO THE MAXIMUM EXTENT PERMITTED BY LAW, GIROKIQ IS PROVIDED "AS IS" WITHOUT WARRANTIES OF ANY KIND. THE DEVELOPER SHALL NOT BE LIABLE FOR ANY INDIRECT, INCIDENTAL, OR CONSEQUENTIAL DAMAGES, INCLUDING LOSS OF DATA OR PROFITS, ARISING OUT OF YOUR USE OF THE APP.
            </p>
          </div>
        </section>

        <section>
          <h2 class="text-2xl font-semibold text-white mb-4 flex items-center gap-3">
            <span class="w-8 h-8 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-sm text-[#C9A84C]">7</span>
            Termination
          </h2>
          <p class="text-gray-300 leading-relaxed">
            The developer reserves the right to suspend or terminate your account at any time, without notice, for conduct that violates these Terms or is otherwise harmful to other users or the developer's interests.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-semibold text-white mb-4 flex items-center gap-3">
            <span class="w-8 h-8 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-sm text-[#C9A84C]">8</span>
            Governing Law
          </h2>
          <p class="text-gray-300 leading-relaxed">
            These Terms are governed by the laws of Mexico. Any disputes arising from these Terms shall be resolved in the competent courts of the developer's jurisdiction.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-semibold text-white mb-4 flex items-center gap-3">
            <span class="w-8 h-8 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-sm text-[#C9A84C]">9</span>
            Changes to Terms
          </h2>
          <p class="text-gray-300 leading-relaxed">
            We may update these Terms from time to time. Continued use of the App after changes are posted constitutes your acceptance of the new Terms.
          </p>
        </section>

        <section class="border-t border-white/10 pt-8 mt-12">
          <h2 class="text-xl font-semibold text-white mb-6">
            Contact Information
          </h2>
          <div class="p-6 rounded-2xl border border-white/10 bg-white/5 inline-block">
            <p class="text-white font-medium mb-1">GirokIQ Team</p>
            <p class="text-gray-400">
              Email: <a href="mailto:support@girokiq.app" class="text-[#C9A84C] hover:underline transition-all">support@girokiq.app</a>
            </p>
          </div>
        </section>
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>
