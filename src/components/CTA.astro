---
import WaitlistForm from './WaitlistForm.astro';
---

<section class="py-32 bg-dark-bg relative overflow-hidden">
  <!-- Glow Effect -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-150 h-150 bg-brand-gold/10 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
    <h2 class="text-5xl md:text-7xl font-bold mb-8 text-white tracking-tight">
      Your ideas deserve more than a <span class="text-gradient">blank page</span>.
    </h2>
    <p class="text-xl text-gray-400 mb-12 max-w-2xl mx-auto">
      Join the waitlist to be among the first to experience GirokIQ when our iPadOS app launches.
    </p>
    
    <div class="flex justify-center">
      <WaitlistForm />
    </div>
  </div>
</section>
