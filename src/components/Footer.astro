---
const links = {
  product: [
    { label: "Features", href: "/#features" },
    { label: "Pricing", href: "/#pricing" },
    { label: "Contact", href: "/contact" },
  ],
  legal: [
    { label: "Privacy Policy", href: "/privacy" },
    { label: "Terms of Service", href: "/terms" },
  ]
};
---

<footer class="bg-[#050505] border-t border-white/5 pt-20 pb-10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
      <div class="col-span-1 md:col-span-2">
        <a href="/" class="flex items-center gap-2 mb-6">
          <img src="/girok-logo-dark.png" alt="GirokIQ" class="h-10 w-auto rounded-[22.37%]" />
        </a>
        <p class="text-gray-500 text-sm leading-relaxed max-w-xs mb-6">
          The infinite canvas for deep thinking. Built natively for iPadOS and Apple Pencil.
        </p>
      </div>

      <div>
        <h4 class="text-white font-semibold mb-6">Product</h4>
        <ul class="space-y-4">
          {links.product.map(link => (
            <li><a href={link.href} class="text-gray-500 hover:text-white transition-colors text-sm">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-white font-semibold mb-6">Legal</h4>
        <ul class="space-y-4">
          {links.legal.map(link => (
            <li><a href={link.href} class="text-gray-500 hover:text-white transition-colors text-sm">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-gray-600 text-sm">
        &copy; {new Date().getFullYear()} GirokIQ. All rights reserved.
      </p>
      <div class="flex items-center gap-6">
         <span class="w-2 h-2 rounded-full bg-brand-gold"></span>
         <span class="text-gray-600 text-sm">Work in Progress</span>
      </div>
    </div>
  </div>
</footer>
