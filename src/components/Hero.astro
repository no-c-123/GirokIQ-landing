---
import WaitlistForm from './WaitlistForm.astro';
---

<section class="relative pt-32 pb-20 overflow-hidden">
  <!-- Background effects -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl pointer-events-none">
    <div class="absolute top-20 left-10 w-72 h-72 bg-brand-gold/10 rounded-full blur-[100px]"></div>
    <div class="absolute top-40 right-10 w-96 h-96 bg-brand-gold-dark/10 rounded-full blur-[100px]"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-sm text-gray-300 mb-8 animate-fade-in-up">
      <span class="w-2 h-2 rounded-full bg-brand-gold animate-pulse"></span>
      <span>Work in Progress iPadOS App</span>
    </div>
    
    <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6 bg-clip-text text-transparent bg-gradient-to-b from-white to-white/60 pb-2">
      Think clearly. <br class="hidden md:block" />
      <span class="bg-clip-text text-transparent bg-gradient-to-r from-brand-gold-light to-brand-gold-dark">Create freely.</span>
    </h1>
    
    <p class="mt-4 max-w-2xl mx-auto text-xl text-gray-400 mb-10 leading-relaxed">
      A native iPadOS notebook designed for Apple Pencil. Combine natural handwriting, text, images, and AI assistants in a distraction-free infinite canvas.
    </p>
    
    <div id="waitlist" class="mb-16 scroll-mt-24">
      <WaitlistForm />
      <div class="mt-6 flex items-center justify-center gap-2 text-sm text-gray-500">
        <a href="#spotlight" class="hover:text-white transition-colors flex items-center">
          <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          See How It Works
        </a>
      </div>
    </div>

    <!-- Hero product shot -->
    <div class="relative max-w-5xl mx-auto animate-fade-in-up">
      <div class="absolute -inset-10 rounded-[3rem] bg-brand-gold/15 blur-3xl opacity-60 pointer-events-none"></div>
      <div class="relative rounded-[1.75rem] p-2.5 sm:p-3 bg-gradient-to-br from-[#2b2b2b] to-[#141414] border border-white/25 shadow-2xl shadow-black/70">
        <div class="rounded-[1.25rem] overflow-hidden aspect-[3/2] border border-white/10 bg-[#171717]">
          <img
            src="/screens/hero.jpg"
            alt="GirokIQ infinite canvas filled with handwritten notes, diagrams and text on iPad"
            width="1503"
            height="1047"
            decoding="async"
            class="w-full h-full object-cover object-top"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes draw {
    to {
      stroke-dashoffset: 0;
    }
  }
  .animate-draw {
    animation: draw 2s ease-out forwards;
  }
</style>
